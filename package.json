{
  "name": "yyeva-workspace",
  "private": true,
  "scripts": {
    "dev": "lerna run dev --parallel",
    "build": "lerna run build",
    "lint": "biome check . --fix",
    "version": "lerna run build",
    "bump": "lerna version --conventional-commits --yes",
    "bump:dryrun": "lerna version --conventional-commits --no-push --no-git-tag-version",
    "release": "lerna version --conventional-commits --yes && lerna publish from-git --yes"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@empjs/biome-config": "^0.7.2",
    "lerna": "^9.0.5",
    "typescript": "^5.4.5"
  }
}
